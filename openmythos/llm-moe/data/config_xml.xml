<?xml version="1.0" encoding="UTF-8"?>
<!--
  XML Training Data
  Configuration files, data formats, and document structures
  that the model should learn to understand and generate.
-->

<!-- ═══════════════════════════════════════════════════════════════════════
     Application Configuration (Spring Boot Style)
     ═══════════════════════════════════════════════════════════════════════ -->

<application xmlns="http://example.com/app/config"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="http://example.com/app/config app-config.xsd">

    <metadata>
        <name>my-application</name>
        <version>3.2.1</version>
        <description>Production application with database and caching</description>
    </metadata>

    <server>
        <host>0.0.0.0</host>
        <port>8080</port>
        <ssl enabled="true">
            <certificate>/etc/ssl/certs/app.crt</certificate>
            <private-key>/etc/ssl/private/app.key</private-key>
            <protocols>TLSv1.2,TLSv1.3</protocols>
        </ssl>
        <compression enabled="true">
            <min-size>2048</min-size>
            <mime-types>text/html,application/json,text/css,application/javascript</mime-types>
        </compression>
    </server>

    <database>
        <primary>
            <driver>org.postgresql.Driver</driver>
            <url>jdbc:postgresql://db-primary:5432/myapp</url>
            <username>${DB_USER}</username>
            <password>${DB_PASSWORD}</password>
            <pool>
                <min-idle>5</min-idle>
                <max-active>20</max-active>
                <max-wait>30000</max-wait>
                <validation-query>SELECT 1</validation-query>
            </pool>
        </primary>
        <replica>
            <url>jdbc:postgresql://db-replica:5432/myapp</url>
            <read-only>true</read-only>
        </replica>
    </database>

    <cache>
        <provider>redis</provider>
        <redis>
            <host>redis.internal</host>
            <port>6379</port>
            <database>0</database>
            <password>${REDIS_PASSWORD}</password>
            <ttl-seconds>3600</ttl-seconds>
            <max-connections>50</max-connections>
        </redis>
        <regions>
            <region name="users" ttl="1800" max-entries="10000" />
            <region name="sessions" ttl="86400" max-entries="50000" />
            <region name="products" ttl="300" max-entries="5000" />
        </regions>
    </cache>

    <logging>
        <level>INFO</level>
        <appenders>
            <console>
                <pattern>[%date{ISO8601}] [%level] [%thread] %logger - %message%n</pattern>
            </console>
            <file>
                <path>/var/log/app/application.log</path>
                <rolling-policy>
                    <max-size>100MB</max-size>
                    <max-history>30</max-history>
                    <total-size>3GB</total-size>
                </rolling-policy>
            </file>
        </appenders>
        <loggers>
            <logger name="com.example.app" level="DEBUG" />
            <logger name="org.hibernate.SQL" level="WARN" />
            <logger name="org.springframework" level="INFO" />
        </loggers>
    </logging>

    <security>
        <cors>
            <allowed-origins>https://app.example.com,https://admin.example.com</allowed-origins>
            <allowed-methods>GET,POST,PUT,DELETE,OPTIONS</allowed-methods>
            <allowed-headers>Authorization,Content-Type,X-Request-ID</allowed-headers>
            <max-age>3600</max-age>
        </cors>
        <rate-limiting>
            <default-limit>100</default-limit>
            <window-seconds>60</window-seconds>
            <endpoints>
                <endpoint path="/api/auth/login" limit="10" window="300" />
                <endpoint path="/api/search" limit="30" window="60" />
            </endpoints>
        </rate-limiting>
    </security>
</application>

<!-- ═══════════════════════════════════════════════════════════════════════
     Maven POM Example
     ═══════════════════════════════════════════════════════════════════════ -->

<project xmlns="http://maven.apache.org/POM/4.0.0">
    <modelVersion>4.0.0</modelVersion>

    <groupId>com.example</groupId>
    <artifactId>ml-pipeline</artifactId>
    <version>1.0.0-SNAPSHOT</version>
    <packaging>jar</packaging>

    <properties>
        <java.version>21</java.version>
        <spring.boot.version>3.2.0</spring.boot.version>
    </properties>

    <dependencies>
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-web</artifactId>
            <version>${spring.boot.version}</version>
        </dependency>
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-data-jpa</artifactId>
            <version>${spring.boot.version}</version>
        </dependency>
        <dependency>
            <groupId>org.postgresql</groupId>
            <artifactId>postgresql</artifactId>
            <version>42.7.0</version>
            <scope>runtime</scope>
        </dependency>

        <!-- Test dependencies -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-test</artifactId>
            <version>${spring.boot.version}</version>
            <scope>test</scope>
        </dependency>
    </dependencies>

    <build>
        <plugins>
            <plugin>
                <groupId>org.springframework.boot</groupId>
                <artifactId>spring-boot-maven-plugin</artifactId>
            </plugin>
        </plugins>
    </build>
</project>

